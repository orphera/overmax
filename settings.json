{
  "window_tracker": {
    "window_title": "DJMAX RESPECT V",
    "poll_interval_sec": 0.5
  },
  "screen_capture": {
    "logo_ocr_cooldown_sec": 1.0,
    "idle_sleep_sec": 0.5
  },
  "debug_window": {
    "max_lines": 500,
    "title": "Overmax Debug Log"
  },
  "overlay": {
    "base_opacity": 0.8,
    "scale": 1.0
  },
  "jacket_matcher": {
    "db_path": "cache/image_index.db",
    "similarity_threshold": 0.75
  },
  "app_update": {
    "enabled": true,
    "owner": "orphera",
    "repo": "overmax",
    "asset_name": "overmax.zip",
    "latest_release_url": ""
  },
  "varchive": {
    "songs_api_url": "https://v-archive.net/db/v2/songs.json",
    "songs_cache_path": "cache/songs.json",
    "dlcs_api_url": "https://v-archive.net/db/dlcs.json",
    "dlcs_cache_path": "cache/dlcs.json",
    "cache_path": "cache/songs.json",
    "cache_ttl_sec": 86400,
    "download_timeout_sec": 10
  }
}